@baseUrl = http://localhost:8080
@productCode = 1
@userCode = 1

### Create stock movement
### Manual stock endpoint. Do not use this for service-order output, which is automatic on finish.
POST {{baseUrl}}/api/v1/stock-movements
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "productCode": "{{productCode}}",
  "movementType": "ENTRY",
  "originType": "MANUAL_ADJUSTMENT",
  "quantity": 10,
  "previousBalance": 20,
  "laterBalance": 30,
  "unitCost": 15.50,
  "notes": "Entrada manual de estoque",
  "movedByCode": "{{userCode}}"
}
