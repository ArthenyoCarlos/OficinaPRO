@baseUrl = http://localhost:8080
@serviceOrderCode = 1
@serviceOrderNumber = OS-1774544009950
@userCode = 1

### Approve service order
### Use only when the order is in WAITING_APPROVAL
### Use serviceOrderCode in the URL. serviceOrderNumber is only the visible OS number.
PATCH {{baseUrl}}/api/v1/service-orders/{{serviceOrderCode}}/approve
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "approvedByCode": "{{userCode}}",
  "approvalMethod": "WHATSAPP",
  "approvalNotes": "Cliente aprovou o orcamento"
}
