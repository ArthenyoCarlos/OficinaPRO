@baseUrl = http://localhost:8080
@serviceOrderCode = 1
@clientCode = 1
@vehicleCode = 1
@userCode = 1

### Update service order
PUT {{baseUrl}}/api/v1/service-orders/{{serviceOrderCode}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "clientCode": "{{clientCode}}",
  "vehicleCode": "{{vehicleCode}}",
  "responsibleTechnicianCode": "{{userCode}}",
  "status": "IN_PROGRESS",
  "reportedProblem": "Motor falhando e consumo alto",
  "diagnosis": "Troca de velas em andamento",
  "internalNotes": "Aguardando teste final",
  "customerNotes": "Cliente deseja retirar hoje",
  "entryMileage": 125000,
  "fuelLevel": "1/2",
  "accessories": "Macaco, chave de roda, estepe",
  "discount": 10.00,
  "serviceItems": [
    {
      "serviceCode": "1",
      "complementaryDescription": "Troca de oleo e filtro",
      "quantity": 1,
      "discount": 0.00,
      "responsibleTechnicianCode": "{{userCode}}"
    }
  ],
  "productItems": [
    {
      "productCode": "1",
      "quantity": 3,
      "discount": 10.00
    }
  ],
  "receipts": [
    {
      "amount": 100.00,
      "paymentMethod": "PIX",
      "notes": "Sinal recebido",
      "receivedByCode": "{{userCode}}"
    }
  ]
}
